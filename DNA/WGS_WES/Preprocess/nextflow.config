// =============================================================================
// Nextflow Configuration — SLURM executor, labels & Apptainer
// =============================================================================

// Resolve SLURM settings from env or defaults
def slurm_account  = System.getenv('SLURM_ACCOUNT')       ?: 'o250022'
def num_gpus       = System.getenv('NUM_GPUS')             ?: '1'
def gpu_partition   = System.getenv('SLURM_GPU_PARTITION') ?: 'gpu'
def cpu_partition   = System.getenv('SLURM_CPU_PARTITION') ?: 'compute'

// Reporting plugins
report {
    enabled   = true
    file      = "results/pipeline_info/execution_report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "results/pipeline_info/execution_timeline.html"
    overwrite = true
}
trace {
    enabled   = true
    file      = "results/pipeline_info/execution_trace.txt"
    overwrite = true
}

// SLURM executor as default
process {
    executor = 'slurm'
    shell    = ['/bin/bash', '-euo', 'pipefail']

    withLabel: 'gpu' {
        queue            = gpu_partition
        cpus             = 40
        memory           = '150 GB'
        time             = '10h'
        clusterOptions   = "--account ${slurm_account} --partition=${gpu_partition} --ntasks=1 --cpus-per-task=40 --gres=gpu:${num_gpus}"
        containerOptions = '--nv --bind /common:/common --bind /project:/project --bind /scratch:/scratch'
        maxForks         = 1
    }

    withLabel: 'cpu_med' {
        queue          = cpu_partition
        cpus           = 12
        memory         = '128 GB'
        time           = '4h'
        clusterOptions = "--account ${slurm_account}"
    }

    withLabel: 'cpu_low' {
        queue          = cpu_partition
        cpus           = 4
        memory         = '32 GB'
        time           = '2h'
        clusterOptions = "--account ${slurm_account}"
    }
}

apptainer {
    enabled    = true
    autoMounts = true
    runOptions = System.getenv('APPTAINER_RUN_OPTS') ?: '--nv --bind /common:/common --bind /project:/project --bind /scratch:/scratch'
}
